#include<iostream>
using namespace std;

class Violation{
    string vno,name,type;
    int fine;
public:
    static int count;

    void getData(string a,string b,string c){
        vno=a; name=b; type=c;

        if(type=="Speed") fine=1500;
        else if(type=="Signal") fine=1000;
        else fine=500;

        count++;
    }

    void display(){
        cout<<vno<<" "<<name<<" "<<type<<" "<<fine<<endl;
    }
};

int Violation::count=0;

int main(){
    Violation v[2];

    v[0].getData("TN01AB1234","Rahul","Speed");
    v[1].getData("TN02CD5678","Kumar","Parking");

    for(int i=0;i<2;i++)
        v[i].display();

    cout<<"Total Violations: "<<Violation::count;
}
